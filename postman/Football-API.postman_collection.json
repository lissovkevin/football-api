    {
      "name": "Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function() {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Returns token\", function() {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.register.token).to.be.a(\"string\");",
              "  pm.environment.set(\"token\", json.data.register.token);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"randomUsername\", \"user_\" + Math.random().toString(36).substring(2, 8));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"mutation { register(username: \\\"{{randomUsername}}\\\", password: \\\"password123\\\") { token message } }\"\n}",
