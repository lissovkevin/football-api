{
  "name": "football-api",
  "version": "1.0.0",
  "description": "GraphQL API for football match data",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "lint": "eslint src/ scripts/",
    "db:push": "npx prisma db push --schema=src/prisma/schema.prisma",
    "db:seed": "node scripts/seed.js",
    "db:studio": "npx prisma studio --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.3",
    "jsonwebtoken": "^9.0.2",
    "ruru": "^2.0.0-beta.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prisma": "^5.22.0"
  }
}
